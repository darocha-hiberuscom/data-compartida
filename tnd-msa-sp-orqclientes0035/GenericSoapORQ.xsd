    					todo1 Tipo: String Longitud: 9 Ejemplo:
    					304100111
    				</xsd:documentation>
    			</xsd:annotation>
    		</xsd:element>

    		<xsd:element name="geolocalizacion" type="xsd:string"
    			maxOccurs="1" minOccurs="1">
    			<xsd:annotation>
