    <xsd:complexType name="GenericError">
        <xsd:annotation>
        	<xsd:documentation>Folder que contiene campos que describen el exito o el error de una invocación a un orquestador o a un microservicio.</xsd:documentation></xsd:annotation>
        <xsd:sequence>
        	<xsd:element name="codigo" type="xsd:string" maxOccurs="1"
        		minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>
        				Código del error presentado en el procesamiento
        				del orquestador o el microservicio y sus
        				invocaciones internas, en caso de exito se
        				respondera con 0. Tipo: String Longitud: N/A
        				Ejemplo: 999
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
        	<xsd:element name="mensaje" type="xsd:string" maxOccurs="1"
        		minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>
        				Mensaje de error presentado en el procesamiento
        				del orquestador o el microservicio y sus
        				invocaciones internas, en caso de exito se
        				respondera con OK. Tipo: String Longitud: N/A
        				Ejemplo: CUENTA NO EXISTE
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
            <xsd:element name="mensajeNegocio" type="xsd:string" maxOccurs="1" minOccurs="1"></xsd:element>
            <xsd:element name="tipo" type="xsd:string" maxOccurs="1"
        		minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>
        				tipo de error presentado en el procesamiento del
        				orquestador o el microservicio y sus
        				invocaciones internas guiado a la severidad del
        				mismo, puede ser de tipo ERROR, FATAL e INFO.
        				Tipo: String Longitud: N/A Ejemplo: INFO
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
        	<xsd:element name="recurso" type="xsd:string" maxOccurs="1"
        		minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>
        				Nombre del módulo invocado del microservicio o
        				el orquestador en el que se produce el error, se
        				presenta con la sintaxis siguiente:
        				nombre/método. Tipo: String Longitud: N/A
        				Ejemplo:
        				WSTransferencias1001/ProcesarTransferenciasDirecta11
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
        	<xsd:element name="componente" type="xsd:string"
        		maxOccurs="1" minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>
        				Nombre del componente en el que se produce el
        				fallo, ese podria ser el metodo mismo del
        				recurso invocado o puede ser un componente de
        				tipo backend como una transacción de bancs.
        				Tipo: String Longitud: N/A Ejemplo: TX067180
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
        	<xsd:element name="backend" type="xsd:string" maxOccurs="1"
        		minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>
        				Código de backend invocado por el componente en
        				el que se produce el error. Tipo: String
        				Longitud: 5 Ejemplo: 00045 (Bancs)
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>

        </xsd:sequence>
    </xsd:complexType>


    <xsd:complexType name="GenericFlow">
        <xsd:annotation>
        	<xsd:documentation>Folder especifico que maneja la interacción entre el aplicativo UI y el orquestador, el manejo se lo realiza a travez de estados y campos dinamicos de tal forma que el orquestador pueda crecer en funcionalidad sin necesidad de cambiar la interface del mismo.</xsd:documentation>
        </xsd:annotation>
        <xsd:sequence>
    		<xsd:element name="estado" type="xsd:string" maxOccurs="1" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>Campo que representa el estado que evalua el aplicativo UI que interactua con el orquestador.</xsd:documentation>
    			</xsd:annotation></xsd:element>
    		<xsd:element name="campos" type="bp:Flow" maxOccurs="1" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>Folder que contiene una colección de campos dinámicos de tipo clave/valor en los cuales se coloca valores a la salida del orquestador que se necesitan en la entrada del mismo para la siguiente interacción</xsd:documentation>
    			</xsd:annotation></xsd:element>
    	</xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="Flow">
        <xsd:annotation>
        	<xsd:documentation>Folder que contiene una colección de campos dinámicos de tipo clave/valor en los cuales se coloca valores a la salida del orquestador que se necesitan en la entrada del mismo para la siguiente iteración.</xsd:documentation></xsd:annotation>
        <xsd:sequence>
    		<xsd:element name="campo" type="bp:Field" maxOccurs="unbounded" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>folder de tipo colección que contiene campos de clave y valor que se utilizan para interactuar con el aplicativo UI.</xsd:documentation>
    			</xsd:annotation></xsd:element>
    	</xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="Field">
        <xsd:annotation>
        	<xsd:documentation>Campo parte de la colección del Flujo que contiene campos de clave valor necesarios para la interacción entre el legacy y el servicio consumido.</xsd:documentation>
        </xsd:annotation>
        <xsd:sequence>
    		<xsd:element name="clave" type="xsd:string" maxOccurs="1" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>Campo que contiene la etiqueta o el nombre de la variable a la cual se le tomara el valor
Tipo: String
Longitud: N/A
Ejemplo: tipoSeguridad</xsd:documentation>
    			</xsd:annotation></xsd:element>
    		<xsd:element name="valor" type="xsd:string" maxOccurs="1" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>Campo que contiene la valor de la etiqueta colocada en el anterior parametro de clave
Tipo: String
Longitud: N/A
Ejemplo: 2</xsd:documentation>
    			</xsd:annotation></xsd:element>
    	</xsd:sequence>
    </xsd:complexType>
    
        <xsd:complexType name="transaccionFinancieraType">
        <xsd:annotation>
        	<xsd:documentation>Folder que contiene campos de respuesta de una transacción financiera especificamente utilizados para notificaciones, registro de log transanccional y para
el reverso manual en caso de ser requerido.</xsd:documentation>
        </xsd:annotation>
        <xsd:sequence>
        	<xsd:element name="fechaContable" type="xsd:string"
        		maxOccurs="1" minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>fecha contable de bancs en la cual se impacta la
transacción financiera Tipo: String Longitud: 8
Ejemplo: 11022017
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
        	<xsd:element name="numeroDocumento" type="xsd:string"
        		minOccurs="1" maxOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>numero unico de transacción en bancs, este permite rastrear datos y poder reversar una
transacción financiera Tipo: String Longitud: 9
Ejemplo: 000061489
        			</xsd:documentation>
        		</xsd:annotation>
        	</xsd:element>
        	<xsd:element name="journals" type="bp:journals" maxOccurs="1" minOccurs="1">
        		<xsd:annotation>
        			<xsd:documentation>Folder que contiene los journal asociados al journal principal asociados a la transacción</xsd:documentation>
        		</xsd:annotation></xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    
        <xsd:complexType name="journals">
        <xsd:annotation>
        	<xsd:documentation>Folder de documentos de journal asociados al journal prinipal de una transaccion financiera</xsd:documentation>
        </xsd:annotation>
        <xsd:sequence>
    		<xsd:element name="journal" type="bp:journal" maxOccurs="unbounded" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>Folder que contiene el valor de los journal asociados al journal principal</xsd:documentation></xsd:annotation></xsd:element>
    	</xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="journal">
        <xsd:annotation>
        	<xsd:documentation>Folder que contiene el valor de los journal asociados al journal principal</xsd:documentation>
        </xsd:annotation>
        <xsd:sequence>
    		<xsd:element name="valor" type="xsd:string" maxOccurs="1" minOccurs="1">
    			<xsd:annotation>
    				<xsd:documentation>Valor del journal o numero de documento:
tipo: String
longitud: 9
ejemplo: 000584129
</xsd:documentation>
    			</xsd:annotation></xsd:element>
    	</xsd:sequence>
    </xsd:complexType>
</xsd:schema>