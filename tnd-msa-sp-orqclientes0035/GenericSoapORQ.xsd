    					trazabilidad con el siguiente formato
    					YYYYMMDDhhmmssnnnn. Se lo utiliza para la
    					trazabilidad en los logs técnicos. Tipo: String
    					Longitud: 18 Ejemplo: 201608161239203000
    				</xsd:documentation>
    			</xsd:annotation>
    		</xsd:element>
